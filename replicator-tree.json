{
  "replicas": {
    "default": {
      "slave1": {
        "role": "master",
        "dialect": "sqlite",
        "uri": ":memory:",
        "pool": {
          "min": 2,
          "max": 20
        }
      }
    }
  },
  "rules": {
    "r1": {
      "source": "default",
      "target": "default",
      "mode": "snapshot",
      "collections": [
        "users"
      ],
      "conflictResolution": "source-wins",
      "enabled": true
    }
  },
  "routing": {
    "default": "round-robin"
  }
}